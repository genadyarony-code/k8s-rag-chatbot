{
  "id": null,
  "uid": "k8s-rag-health",
  "title": "K8s RAG Chatbot — Health",
  "description": "Request rate, latency, error indicators, and index health",
  "tags": ["k8s-rag", "health"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(chat_requests_total[5m])",
          "legendFormat": "session: {{session_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "P50 / P95 / P99 Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(chat_latency_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(chat_latency_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(chat_latency_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "title": "ChromaDB Index Health",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "index_health{index_type=\"chroma\"}",
          "legendFormat": "ChromaDB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DEGRADED", "color": "red" }, "1": { "text": "HEALTHY", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "BM25 Index Health",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "index_health{index_type=\"bm25\"}",
          "legendFormat": "BM25"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DEGRADED", "color": "red" }, "1": { "text": "HEALTHY", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "circuit_breaker_state{breaker=\"openai_api\"}",
          "legendFormat": "OpenAI"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "CLOSED", "color": "green" },
              "1": { "text": "HALF-OPEN", "color": "yellow" },
              "2": { "text": "OPEN", "color": "red" }
            }}
          ]
        }
      }
    },
    {
      "id": 6,
      "title": "Feature Flag Status",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "feature_flag_status",
          "legendFormat": "{{flag_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFF", "color": "orange" }, "1": { "text": "ON", "color": "green" } } }
          ]
        }
      }
    }
  ]
}
