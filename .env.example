# Required
OPENAI_API_KEY=sk-...

# Optional — override defaults
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
TOP_K_RESULTS=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNK_SCHEMA_VERSION=v1.0

# Feature Flags — operational killswitches (core)
FF_USE_CHROMA=true
FF_USE_OPENAI=true
FF_USE_SESSION_MEMORY=true
FF_USE_STREAMING=true

# Feature Flags — RAG quality (disable individually to A/B test improvements)
FF_USE_HYBRID_SEARCH=true
FF_USE_RERANKING=true
FF_USE_QUERY_DECOMPOSITION=true
FF_USE_CITATION_VALIDATION=false  # Requires ~2 GB sentence-transformers/torch

# Evaluation settings
EVAL_SAMPLE_RATE=0.1   # 10% of live requests are evaluated with LLM-as-judge

# Security — disable only for local dev / load testing, never in production
SECURITY_ENABLE_PROMPT_INJECTION_CHECK=true
SECURITY_ENABLE_PII_DETECTION=true
SECURITY_ENABLE_RATE_LIMITING=true
MAX_INPUT_LENGTH=5000

# Observability — distributed tracing
ENVIRONMENT=development
TRACING_ENABLED=true
OTLP_ENDPOINT=              # e.g. http://localhost:4317 (leave blank for console output)

# Authentication — set to true in production to require API keys on /chat
ENABLE_AUTH=false

# Cost Controls — token budgets and spending limits
TOKEN_BUDGET_SESSION_DAILY=100000
TOKEN_BUDGET_GLOBAL_DAILY=1000000
TOKEN_BUDGET_PER_REQUEST=10000
COST_WARNING_THRESHOLD_USD=10.0
COST_HARD_LIMIT_USD=50.0
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60
